DATABASE_URL=postgres://postgres:postgres@localhost:5432/solar_forecast?sslmode=disable
PORT=8080
FRONTEND_ORIGIN=http://localhost:5173
AUTH_JWT_SECRET=change-this-jwt-secret
AUTH_TOKEN_EXPIRY_HOURS=24
AUTH_REFRESH_TOKEN_EXPIRY_DAYS=7
FORECAST_DEBUG_TOKEN=

# SMTP for email notification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_email@gmail.com

# Telegram notification (free channel)
TELEGRAM_BOT_TOKEN=

# WhatsApp Cloud API (paid channel)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=solar_forecast_daily
WHATSAPP_TEMPLATE_LANG=id

# Weather API (Open-Meteo is free, no key needed)
WEATHER_BASE_URL=https://api.open-meteo.com/v1
